rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DEVELOPMENT MODE - OPEN ACCESS
    // ⚠️ WARNING: These rules allow anyone to read/write all data
    // ⚠️ DO NOT USE IN PRODUCTION!
    
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
